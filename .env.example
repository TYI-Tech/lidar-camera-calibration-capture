# Docker image built by this kit.
CALIBRATION_CAPTURE_IMAGE=lidar-camera-calibration-capture:0.1.0

# Public ROS Noetic image. Override this if your robot already has a prepared
# ROS image with matching livox_ros_driver2 messages.
CALIBRATION_CAPTURE_BASE_IMAGE=ros:noetic-ros-base-focal

# Keep true for a public ROS base image. Set false only when your own base image
# already contains the ROS Noetic runtime, camera_calibration, rosbag, and build
# tools.
CALIBRATION_CAPTURE_INSTALL_APT_DEPS=true

# ROS master on the host. network_mode=host lets the container reach 127.0.0.1.
ROS_MASTER_PORT=11311
ROS_MASTER_URI=http://127.0.0.1:11311
ROS_HOSTNAME=127.0.0.1

# Runtime UID/GID used for generated bags and logs. The wrapper script exports
# the current host user automatically; these defaults are for direct compose use.
CALIBRATION_RUN_UID=1000
CALIBRATION_RUN_GID=1000

# Livox MID360 ROS topics.
CALIBRATION_LIVOX_INPUT_TOPIC=/livox/lidar
CALIBRATION_POINTS_TOPIC=/calibration/livox/points
CALIBRATION_POINTS_FRAME_ID=livox_frame

# USB RGB camera ROS topics.
CALIBRATION_IMAGE_TOPIC=/usb_cam/image_raw
CALIBRATION_CAMERA_INFO_TOPIC=/usb_cam/camera_info
CALIBRATION_INTRINSIC_CAMERA_NS=/usb_cam

# Chessboard inner-corner count and square size. A 9x13-square board has
# 8x12 inner corners, so pass 12 8 0.020 to intrinsics-calibrate.
CALIBRATION_INTRINSIC_PATTERN_COLUMNS=12
CALIBRATION_INTRINSIC_PATTERN_ROWS=8
CALIBRATION_INTRINSIC_SQUARE_M=0.020

# Recording.
CALIBRATION_DURATION_SEC=15
CALIBRATION_WAIT_TIMEOUT_SEC=20
CALIBRATION_RECORD_DEPTH=false
CALIBRATION_DEPTH_TOPIC=

# X11 GUI for ROS camera_calibration.
DISPLAY=:0
